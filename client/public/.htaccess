Options -MultiViews

# ═════════════════════════════════════════════════════════════════
# 0. COMPRESSION — GZIP all text assets (cuts transfer size 60-80%)
# ═════════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
  AddOutputFilterByType DEFLATE application/font-woff application/font-woff2
</IfModule>

# ═════════════════════════════════════════════════════════════════
# 0b. BROWSER CACHING — long cache for static assets, no-cache HTML
# ═════════════════════════════════════════════════════════════════
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML — never cache (always fresh)
  ExpiresByType text/html                    "access plus 0 seconds"
  # CSS + JS — Vite hashes filenames so safe to cache long
  ExpiresByType text/css                     "access plus 1 year"
  ExpiresByType application/javascript       "access plus 1 year"
  # Images
  ExpiresByType image/jpeg                   "access plus 6 months"
  ExpiresByType image/png                    "access plus 6 months"
  ExpiresByType image/webp                   "access plus 6 months"
  ExpiresByType image/svg+xml                "access plus 1 year"
  ExpiresByType image/x-icon                 "access plus 1 year"
  # Fonts
  ExpiresByType font/woff                    "access plus 1 year"
  ExpiresByType font/woff2                   "access plus 1 year"
  ExpiresByType application/font-woff2       "access plus 1 year"
  # Data
  ExpiresByType application/json             "access plus 0 seconds"
  ExpiresByType application/xml              "access plus 1 hour"
</IfModule>

# ═════════════════════════════════════════════════════════════════
# 0c. SECURITY HEADERS — improve PageSpeed Best Practices score
# ═════════════════════════════════════════════════════════════════
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set X-XSS-Protection         "1; mode=block"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=()"
  # HSTS — DISABLED. Do not enable includeSubDomains/preload unless every
  # subdomain has valid SSL, as it locks them to HTTPS for the max-age period.
  # Header always set Strict-Transport-Security "max-age=31536000"

  # Cache headers for hashed static files (Vite output)
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # No-cache for HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

RewriteEngine On

# ═════════════════════════════════════════════════════════════════
# 1. STRIP TRAILING SLASHES
#    Exception: document root "/" is left alone.
# ═════════════════════════════════════════════════════════════════
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ═════════════════════════════════════════════════════════════════
# 2. PAGE REDIRECTS  (old slug → new slug)
# ═════════════════════════════════════════════════════════════════
RewriteRule ^about-us$               /about          [R=301,L]
RewriteRule ^contact-us$             /contact        [R=301,L]
RewriteRule ^privacy-policy$         /privacy        [R=301,L]
RewriteRule ^terms-of-service$       /terms          [R=301,L]
RewriteRule ^faqs$                   /faq            [R=301,L]

# ═════════════════════════════════════════════════════════════════
# 3. SERVICE PAGE REDIRECTS  (old slug → /services/slug)
# ═════════════════════════════════════════════════════════════════
RewriteRule ^administrative-support$   /services/administrative-support   [R=301,L]
RewriteRule ^accounting-services$      /services/accounting-services      [R=301,L]
RewriteRule ^social-media-management$  /services/social-media-management  [R=301,L]
RewriteRule ^marketing-support$        /services/marketing-support        [R=301,L]
RewriteRule ^content-creation$         /services/content-creation         [R=301,L]
RewriteRule ^customer-support$         /services/customer-support         [R=301,L]
RewriteRule ^lead-generation$          /services/lead-generation          [R=301,L]
RewriteRule ^project-management$       /services/project-management       [R=301,L]
RewriteRule ^e-commerce-services$      /services/e-commerce-services      [R=301,L]

# ═════════════════════════════════════════════════════════════════
# 4. BLOG POST REDIRECTS  (old slug → /blog/slug)
# ═════════════════════════════════════════════════════════════════
RewriteRule ^how-virtual-assistant-services-for-small-businesses-can-save-you-20-hours-a-week$ /blog/virtual-assistant-small-business-save-20-hours        [R=301,L]
RewriteRule ^how-an-amazon-virtual-assistant$                                                  /blog/amazon-real-estate-virtual-assistant-services-2026    [R=301,L]
RewriteRule ^10-tasks-you-should-outsource$                                                    /blog                                                        [R=301,L]

# ═════════════════════════════════════════════════════════════════
# 4. REACT SPA FALLBACK
#    Any path that isn't a real file/directory → index.html
# ═════════════════════════════════════════════════════════════════
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
