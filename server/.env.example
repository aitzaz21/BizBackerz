PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/bizbackerz

# Email (Gmail — use an App Password, NOT your account password)
# Setup: Google Account → Security → 2FA → App Passwords → Create
EMAIL_FROM=yourmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Admin notification recipient (for contact-form alerts)
ADMIN_EMAIL=youradmin@gmail.com

# Admin Panel Login (for /admin dashboard)
ADMIN_PANEL_EMAIL=admin@bizbackerz.com
ADMIN_PASSWORD=YourSecurePassword123

# JWT Secret — change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_string

# Cloudinary (for blog & review image uploads)
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
