{
  "name": "bizbackerz",
  "private": true,
  "version": "3.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "build": "npm run build -w client",
    "preview": "npm run preview -w client",
    "server": "npm run start -w server",
    "server:dev": "npm run dev -w server",
    "lighthouse": "lhci autorun",
    "lighthouse:local": "lhci collect --url=http://localhost:4173 --numberOfRuns=1 --config=lighthouserc.js && lhci assert --config=lighthouserc.js"
  }
}
